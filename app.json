{
  "expo": {
    "name": "ColorMind",
    "slug": "colormind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weblity.colormind",
      "buildNumber": "26",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-9254337095601557~3384473164"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.weblity.colormind",
      "versionCode": 1,
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-9254337095601557~3384473164"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9254337095601557~3384473164",
          "iosAppId": "ca-app-pub-9254337095601557~3384473164"
        }
      ]
    ],
    "extra": {
      "eas": {}
    }
  }
}
